<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container">
    <div class="card">
      <h2><%= item ? 'Chỉnh sửa nội dung' : 'Tạo nội dung' %></h2>
      <form method="<%= method %>" action="<%= action %>">
        <label>Title</label>
        <input name="title" value="<%= item?.title || '' %>" required />

        <label>Body</label>
        <textarea name="body" rows="6"><%= item?.body || '' %></textarea>

        <div class="row">
          <div>
            <label>Type</label>
            <select name="type">
              <% ['article','page','image','video'].forEach((t) => { %>
                <option value="<%= t %>" <%= item?.type === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label>Status</label>
            <select name="status">
              <% ['draft','published','archived'].forEach((s) => { %>
                <option value="<%= s %>" <%= item?.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <label>Media URL</label>
        <input name="mediaUrl" value="<%= item?.mediaUrl || '' %>" />
        <button class="btn" type="submit">Lưu</button>
      </form>
    </div>
  </div>
</body>
</html>
