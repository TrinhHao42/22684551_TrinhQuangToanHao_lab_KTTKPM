<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container">
    <div class="card">
      <h2>Quản lý nội dung</h2>
      <a class="btn" href="/contents/new">Tạo nội dung</a>
      <table>
        <thead>
          <tr><th>Tiêu đề</th><th>Loại</th><th>Trạng thái</th><th>Tác giả</th><th></th></tr>
        </thead>
        <tbody>
          <% contents.forEach((item) => { %>
            <tr>
              <td><%= item.title %></td>
              <td><%= item.type %></td>
              <td><%= item.status %></td>
              <td><%= item.author?.username || '-' %></td>
              <td class="actions">
                <a class="btn secondary" href="/contents/<%= item._id %>/edit">Sửa</a>
                <form method="POST" action="/contents/<%= item._id %>?_method=DELETE">
                  <button class="btn secondary" type="submit">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
