<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
</head>
<body>
  <%- include('../partials/nav', { user }) %>
  <div class="container">
    <div class="card">
      <h2>Post Plugin - Quản lý nội dung</h2>
      <form action="/admin/posts" method="POST">
        <label>Title</label>
        <input name="title" required />
        <label>Body</label>
        <textarea rows="5" name="body"></textarea>
        <label>Status</label>
        <select name="status">
          <option value="draft">draft</option>
          <option value="published">published</option>
          <option value="archived">archived</option>
        </select>
        <button class="btn" type="submit">Tạo bài viết</button>
      </form>
    </div>

    <div class="card">
      <table>
        <thead><tr><th>Title</th><th>Status</th><th>Author</th><th></th></tr></thead>
        <tbody>
          <% posts.forEach((p) => { %>
            <tr>
              <td><%= p.title %></td>
              <td><%= p.status %></td>
              <td><%= p.author?.username || '-' %></td>
              <td>
                <form style="display:inline-block" method="POST" action="/admin/posts/<%= p._id %>?_method=DELETE">
                  <button class="btn alt" type="submit">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
